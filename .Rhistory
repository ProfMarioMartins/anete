url <- "https://docs.google.com/spreadsheets/d/14-fjfQ4OeZfhcsL1onnAtDnrfAShhKgJXHjRHJdSRj4"
# Ler a aba específica
dados_org <- read_sheet(url, sheet = "Organização e logística do evento")
url
